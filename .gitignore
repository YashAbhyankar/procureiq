# Secrets — NEVER commit
.env

# Generated data — too large, gitignored; regenerated by `make seed`
data/raw/

# MLflow experiment runs — regenerated by training scripts
mlruns/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.ipynb_checkpoints/

# dbt build artifacts — regenerated by `dbt run`
target/
dbt_packages/
.dbt/

# Airflow logs — fills up fast, not useful in git
airflow/logs/

# OS
.DS_Store
*.swp
Thumbs.db
