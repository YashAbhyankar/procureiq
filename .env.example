# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env — it's in .gitignore.
# ─────────────────────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=procureiq_dev_password

# Airflow (50000 is the standard non-root UID for the official image)
AIRFLOW_UID=50000

# ─── LLM Provider ────────────────────────────────
# Options: groq (default/free) | claude | openrouter
LLM_PROVIDER=groq

# Groq — free tier, sufficient for 200-word digest tasks
GROQ_API_KEY=your_groq_key_here

# OpenRouter — paid, more model options
OPENROUTER_API_KEY=your_openrouter_key_here

# Claude — set LLM_PROVIDER=claude to use locally; keep this key private
CLAUDE_API_KEY=your_claude_key_here

# MLflow
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow/mlruns.db
